---
interface Props {
  title: string;
  description: string;
  image?: string;
}

const { 
  title, 
  description, 
  // Zde definujeme defaultní obrázek. Musíš ho nahrát do složky `public/og-image.jpg`
  image = '/og-image.jpg' 
} = Astro.props;

// Vytvoření absolutních URL adres pro kanonický link a Open Graph
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const ogImageURL = new URL(image, Astro.site || Astro.url.origin);
---

<!-- Základní Meta Tagy -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<meta name="generator" content={Astro.generator} />

<!-- Canonical URL (Zabraňuje penalizaci za duplicitní obsah u Google) -->
<link rel="canonical" href={canonicalURL} />

<!-- Primární Meta Tagy -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="Marek Potuček" />
<meta name="robots" content="index, follow" />

<!-- Open Graph / Facebook / LinkedIn -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:site_name" content="Marek Potuček | Portfolio" />
<meta property="og:locale" content="en_US" />