---
// src/components/Lightbox.astro
---

<!-- ARIA atributy dělají z modalu oficiální "dialog" pro prohlížeče -->
<div 
  id="lightbox" 
  class="lightbox" 
  role="dialog" 
  aria-modal="true" 
  aria-label="Image gallery fullscreen view"
>
  <button id="lightbox-close" class="lightbox-btn close-btn" aria-label="Close gallery">&times;</button>
  
  <!-- Tlačítka pro listování -->
  <button id="lightbox-prev" class="lightbox-btn nav-btn prev-btn" aria-label="Previous image">&#10094;</button>
  <button id="lightbox-next" class="lightbox-btn nav-btn next-btn" aria-label="Next image">&#10095;</button>

  <div class="lightbox-container">
    <img id="lightbox-img" alt="Full screen photograph" />
  </div>
</div>

<style>
  .lightbox {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.95);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 9999;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
    backdrop-filter: blur(10px);
  }

  .lightbox.active {
    opacity: 1;
    pointer-events: auto;
  }

  .lightbox-container {
    width: 100%;
    height: 100%;
    display: flex;
    padding: 3rem;
    justify-content: center;
    align-items: center;
  }

  #lightbox-img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    border-radius: 4px;
    box-shadow: 0 0 40px rgba(0,0,0,0.6);
    /* Jemná animace při změně fotky */
    transition: opacity 0.2s ease, transform 0.2s ease;
  }

  /* --- Společné styly pro ovládací tlačítka --- */
  .lightbox-btn {
    position: absolute;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255,255,255,0.1);
    color: white;
    cursor: pointer;
    z-index: 10000;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    backdrop-filter: blur(5px);
  }

  .lightbox-btn:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.1);
  }

  .close-btn {
    top: 1.5rem;
    right: 1.5rem;
    width: 50px;
    height: 50px;
    font-size: 2rem;
    line-height: 1;
  }

  .nav-btn {
    top: 50%;
    transform: translateY(-50%);
    width: 60px;
    height: 60px;
    font-size: 1.5rem;
  }

  .nav-btn:hover {
    transform: translateY(-50%) scale(1.1);
  }

  .prev-btn { left: 1.5rem; }
  .next-btn { right: 1.5rem; }

  @media (max-width: 768px) {
    .nav-btn { width: 45px; height: 45px; }
    .prev-btn { left: 0.5rem; }
    .next-btn { right: 0.5rem; }
    .lightbox-container { padding: 1rem; }
  }
</style>

<script>
  // === Stav (modul-scope) – přežívá view transitions, proto se elementy obnovují v setup() ===
  let lightbox: HTMLElement | null = null;
  let lightboxImg: HTMLImageElement | null = null;
  let closeBtn: HTMLElement | null = null;
  let prevBtn: HTMLElement | null = null;
  let nextBtn: HTMLElement | null = null;

  let imagesList: string[] = [];   // velké (fullscreen) varianty
  let thumbsList: string[] = [];   // náhledy – fallback, když velká varianta selže
  let currentIndex = 0;
  let lastFocusedElement: HTMLElement | null = null;
  let keydownBound = false;        // document keydown navázat jen jednou

  const isActive = () => !!lightbox?.classList.contains('active');

  // Naplnění polí z DOM (jen položky, které nejsou skryté případným filtrem)
  const updateImagesList = () => {
    imagesList = [];
    thumbsList = [];
    document.querySelectorAll('.gallery-item').forEach((item) => {
      if ((item as HTMLElement).style.display === 'none') return;
      const full = item.getAttribute('data-full-src') || '';
      const thumbImg = item.querySelector('img') as HTMLImageElement | null;
      const thumb = thumbImg?.currentSrc || thumbImg?.src || '';
      if (full || thumb) {
        imagesList.push(full || thumb); // kdyby chybělo data-full-src, použij rovnou náhled
        thumbsList.push(thumb);
      }
    });
  };

  const updateImageDisplay = (index: number) => {
    if (!lightboxImg) return;
    const src = imagesList[index];
    if (!src) return; // nikdy nenastavovat prázdné src (vyhne se „rozbité" ikoně)
    lightboxImg.style.opacity = '0';
    lightboxImg.style.transform = 'scale(0.98)';
    setTimeout(() => {
      if (!lightboxImg) return;
      lightboxImg.src = src;
      lightboxImg.style.opacity = '1';
      lightboxImg.style.transform = 'scale(1)';
    }, 150);
  };

  const openLightbox = (index: number, triggerElement: HTMLElement) => {
    if (!lightbox) return;
    updateImagesList();
    lastFocusedElement = triggerElement;
    currentIndex = index;
    updateImageDisplay(currentIndex);
    lightbox.classList.add('active');
    document.body.style.overflow = 'hidden'; // zamknout scroll pozadí
    closeBtn?.focus();
  };

  const closeLightbox = () => {
    if (!lightbox) return;
    lightbox.classList.remove('active');
    document.body.style.overflow = '';
    setTimeout(() => { if (lightboxImg) lightboxImg.removeAttribute('src'); }, 300);
    lastFocusedElement?.focus(); // vrátit fokus na fotku, ze které se otevíralo
  };

  const nextImage = (e?: Event) => {
    e?.stopPropagation();
    if (imagesList.length === 0) return;
    currentIndex = (currentIndex + 1) % imagesList.length;
    updateImageDisplay(currentIndex);
  };

  const prevImage = (e?: Event) => {
    e?.stopPropagation();
    if (imagesList.length === 0) return;
    currentIndex = (currentIndex - 1 + imagesList.length) % imagesList.length;
    updateImageDisplay(currentIndex);
  };

  // Jednoduchý focus trap – drží Tab uvnitř dialogu (cyklí mezi close/prev/next)
  const trapFocus = (e: KeyboardEvent) => {
    const focusables = [closeBtn, prevBtn, nextBtn].filter(Boolean) as HTMLElement[];
    if (focusables.length === 0) return;
    e.preventDefault();
    const current = focusables.indexOf(document.activeElement as HTMLElement);
    const dir = e.shiftKey ? -1 : 1;
    const target = focusables[(Math.max(0, current) + dir + focusables.length) % focusables.length];
    target.focus();
  };

  const onKeydown = (e: KeyboardEvent) => {
    if (!isActive()) return;
    if (e.key === 'Escape') closeLightbox();
    else if (e.key === 'ArrowRight') nextImage();
    else if (e.key === 'ArrowLeft') prevImage();
    else if (e.key === 'Tab') trapFocus(e);
  };

  // Když se velká varianta nenačte (404 / nenasazený asset / pomalý dev převod),
  // spadni zpět na náhled, který už je na stránce načtený → uživatel uvidí fotku,
  // ne rozbitou ikonu. Do konzole vypíšeme, co selhalo (diagnostika).
  const onImgError = () => {
    if (!lightboxImg) return;
    const failed = lightboxImg.getAttribute('src') || '';
    if (!failed) return;
    const thumb = thumbsList[currentIndex];
    if (thumb && failed !== thumb) {
      console.warn('[lightbox] fullscreen varianta se nenačetla, používám náhled:', failed);
      lightboxImg.src = thumb;
    } else {
      console.error('[lightbox] obrázek se nenačetl:', failed);
    }
  };

  const setup = () => {
    // Tyto elementy jsou po každé navigaci NOVÉ → vždy znovu načíst reference
    lightbox = document.getElementById('lightbox');
    lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
    closeBtn = document.getElementById('lightbox-close');
    prevBtn = document.getElementById('lightbox-prev');
    nextBtn = document.getElementById('lightbox-next');

    const galleryItems = document.querySelectorAll('.gallery-item');
    if (!lightbox || !lightboxImg || galleryItems.length === 0) return;

    // Klik na fotky (nové elementy → navázat pokaždé)
    galleryItems.forEach((item, index) => {
      item.addEventListener('click', (e) => {
        openLightbox(index, e.currentTarget as HTMLElement);
      });
    });

    // Ovládací prvky lightboxu se s view transitions taky vyměňují → navázat pokaždé
    closeBtn?.addEventListener('click', closeLightbox);
    nextBtn?.addEventListener('click', (e) => nextImage(e));
    prevBtn?.addEventListener('click', (e) => prevImage(e));
    lightbox.addEventListener('click', (e) => {
      if (e.target === lightbox || (e.target as HTMLElement).classList.contains('lightbox-container')) {
        closeLightbox();
      }
    });

    // onerror na <img> – #lightbox-img je po navigaci nový, ale guard držíme přes errorBound,
    // protože element se mění; raději navázat pokaždé na aktuální img:
    lightboxImg.addEventListener('error', onImgError);

    // document PŘEŽÍVÁ view transitions → keydown navázat jen jednou (jinak by se hromadil)
    if (!keydownBound) {
      document.addEventListener('keydown', onKeydown);
      keydownBound = true;
    }
  };

  document.addEventListener('astro:page-load', setup);
</script>
