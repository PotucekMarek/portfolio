---
// src/components/SchemaPerson.astro
const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Marek Potuček",
  "jobTitle": "Photographer & Frontend Developer",
  "url": Astro.site ? Astro.site.toString() : "https://www.marekpotucek.com/",
  "image": new URL("/og-image.jpg", Astro.site || "https://www.marekpotucek.com/").toString(),
  "sameAs": [
    // TODO: Zde doplň reálné odkazy na tvé sítě, jakmile je budeš mít.
    // Nech prázdné stringy nebo zakomentuj, pokud zatím žádné nemáš.
    "https://www.instagram.com/yourprofile", 
    "https://www.linkedin.com/in/yourprofile"
  ]
};
---

<!-- set:html zajistí, že Astro vloží JSON objekt přímo jako text bez úprav -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />