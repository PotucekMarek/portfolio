---
// src/components/SchemaPerson.astro
const site = Astro.site ?? new URL("https://www.marekpotucek.com/");

const schema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Marek Potuček",
  "jobTitle": "Photographer, QA Tester & Full-stack Developer",
  "url": site.toString(),
  "image": new URL("/og-image.jpg", site).toString(),
  "sameAs": [
    "https://github.com/PotucekMarek",
    // Až budeš mít, odkomentuj a doplň reálné profily:
    // "https://www.linkedin.com/in/tvuj-profil/",
    // "https://www.instagram.com/tvuj-profil/",
  ],
};
---

<!-- set:html vloží JSON přímo jako text bez úprav -->
<script type="application/ld+json" set:html={JSON.stringify(schema)} />
