---
// src/components/SchemaGallery.astro
interface Props {
  // Každá položka má optimalizovanou URL (full) a alt text.
  images: { full: string; alt: string }[];
}

const { images } = Astro.props;
const base = Astro.site ?? new URL("https://www.marekpotucek.com/");

const schema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Photography Portfolio | Marek Potuček",
  "url": new URL(Astro.url.pathname, base).toString(),
  "mainEntity": {
    "@type": "ImageGallery",
    "image": images.map((img) => ({
      "@type": "ImageObject",
      "contentUrl": new URL(img.full, base).toString(),
      "caption": img.alt,
    })),
  },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />
