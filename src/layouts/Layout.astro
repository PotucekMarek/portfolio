---
import { ClientRouter } from 'astro:transitions';
import Navigation from '../components/Navigation.astro';
import Lightbox from '../components/Lightbox.astro';
import SEO from '../components/SEO.astro'; // <--- Nový import SEO komponenty

interface Props {
  title: string;
  description?: string;
  image?: string; // <--- Přidáno pro možnost vlastního OG obrázku na podstránkách
}

const { 
  title, 
  description = "Marek Potuček is a casual photographer and frontend/backend developer and QA tester of government SW. Explore the fine art portfolio capturing moments.", 
  image 
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Zde voláme SEO komponentu, která vygeneruje veškeré meta tagy, Open Graph, atd. -->
    <SEO title={title} description={description} image={image} />
    
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    
    <ClientRouter />
  </head>
  <body>
    <Navigation />
    
    <main class="content-wrapper">
      <slot />
    </main>
    
    <Lightbox />

    <style is:global>
      :root {
        --bg-color: #0a0a0a;
        --text-color: #ededed;
        --accent-color: #ffffff;
        --secondary-color: #555555;
        --spacing: 2rem;
      }

      *, *::before, *::after {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
      }

      html {
        background-color: var(--bg-color);
        color: var(--text-color);
        font-family: system-ui, -apple-system, sans-serif;
        scroll-behavior: smooth;
      }

      body {
        min-height: 100vh;
        -webkit-font-smoothing: antialiased;
      }

      .content-wrapper {
        max-width: 1600px;
        margin: 0 auto;
        padding: var(--spacing);
      }

      /* Custom Scrollbar for a premium feel */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        background: var(--bg-color);
      }
      ::-webkit-scrollbar-thumb {
        background: #222;
        border-radius: 10px;
      }
      ::-webkit-scrollbar-thumb:hover {
        background: #333;
      }

      /* Base Typography */
      h1, h2, h3 {
        color: var(--accent-color);
        font-weight: 300;
        letter-spacing: -0.02em;
      }
    </style>
  </body>
</html>