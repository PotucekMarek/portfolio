---
import Layout from '../layouts/Layout.astro';
import GalleryItem from '../components/GalleryItem.astro';
import SchemaGallery from '../components/SchemaGallery.astro';

const images = import.meta.glob<{ default: ImageMetadata }>('../assets/gallery/*.{jpeg,jpg,png,webp}', { eager: true });

const imageMetadata: Record<string, { alt: string }> = {
  'PXL_20250928_084411182.PORTRAIT': { alt: 'Hungary trip with girlfriend' },
  'PXL_20250928_112819180.PORTRAIT': { alt: 'Me with girlfriend in Budapest' },
  'PXL_20250928_134521057': { alt: 'Portrait of my gf in Budapest' },
  'PXL_20251002_120447663': { alt: 'Girlfriend in zoo with goat' },
  'PXL_20251014_145141427.PORTRAIT~2': { alt: 'My fat friend Kuba with cat'},
  'PXL_20251018_195201805.PORTRAIT~2': { alt: 'My friend Vojta with Kajinek in Casino in Olomouc' },
  'PXL_20251026_073022640': { alt: 'Saving lobsters' },
  'PXL_20250714_105820798~2.jpg': { alt: 'View from my office' }

};

const imageList = Object.entries(images).map(([path, module]) => {
  const fileName = path.split('/').pop()?.replace(/\.(jpeg|jpg|png|webp)$/i, '') || '';
  
  const meta = imageMetadata[fileName] || { 
    alt: `Photograph titled ${fileName.replace(/[-_]/g, ' ')}` 
  };

  return {
    src: module.default,
    alt: meta.alt,
  };
});
---

<Layout title="Gallery | Marek Potuček">
  <SchemaGallery images={imageList} />
  <div class="bg-grid"></div>
  <div class="ambient-glow glow-1"></div>

  <header class="gallery-header">
    <h1 class="animate-fade-in">Selected <span class="text-gradient">Works</span></h1>
    <p class="subtitle animate-fade-in" style="animation-delay: 0.2s">
      A collection of moments worth preserving.
    </p>
  </header>

  <section class="masonry-grid">
    {imageList.map((img, index) => (
      <GalleryItem image={img.src} alt={img.alt} index={index} />
    ))}
  </section>
</Layout>

<style>

  .bg-grid {
    position: fixed;
    inset: 0;
    z-index: -2;
    background-size: 40px 40px;
    background-image: linear-gradient(to right, rgba(255, 255, 255, 0.02) 1px, transparent 1px),
                      linear-gradient(to bottom, rgba(255, 255, 255, 0.02) 1px, transparent 1px);
    mask-image: radial-gradient(circle at top, black 20%, transparent 100%);
    -webkit-mask-image: radial-gradient(circle at top, black 20%, transparent 100%);
  }

  .ambient-glow {
    position: fixed;
    top: -20%;
    left: 20%;
    width: 60vw;
    height: 60vw;
    border-radius: 50%;
    background: #4a90e2;
    filter: blur(150px);
    opacity: 0.08;
    z-index: -1;
    pointer-events: none;
  }

  .gallery-header {
    text-align: center;
    margin: 4rem 0 6rem 0;
    padding: 0 var(--spacing);
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4.5rem);
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--text-color);
  }

  .text-gradient {
    background: linear-gradient(to right, #fff, #666, #fff);
    background-size: 200% auto;
    color: transparent;
    -webkit-background-clip: text;
    background-clip: text;
    animation: shine 4s linear infinite;
  }

  .subtitle {
    color: #888;
    margin-top: 1.5rem;
    font-size: 1.2rem;
    letter-spacing: 0.02em;
  }

  .masonry-grid {
    column-count: 1;
    column-gap: var(--spacing);
    padding: 0 var(--spacing) 4rem var(--spacing);
    width: 100%;
    max-width: 1800px;
    margin: 0 auto;
  }

  @media (min-width: 768px) { .masonry-grid { column-count: 2; } }
  @media (min-width: 1200px) { .masonry-grid { column-count: 3; } }

  .animate-fade-in {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes fadeIn { to { opacity: 1; transform: translateY(0); } }
  @keyframes shine { to { background-position: 200% center; } }
</style>