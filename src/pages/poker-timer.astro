---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Poker Timer">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet" />

  <div class="poker-timer-app">
    <div id="loader">
      <img src="/chip.png" alt="" />
    </div>

    <div class="icon-wrapper top-left" aria-hidden="true"><i class="bi bi-suit-heart big-icon"></i></div>
    <div class="icon-wrapper top-right" aria-hidden="true"><i class="bi bi-suit-diamond big-icon"></i></div>
    <div class="icon-wrapper bottom-left" aria-hidden="true"><i class="bi bi-suit-club big-icon"></i></div>
    <div class="icon-wrapper bottom-right" aria-hidden="true"><i class="bi bi-suit-spade big-icon"></i></div>

    <div id="saveMessage" class="alert alert-success d-none" role="status" aria-live="polite" data-i18n="saveSuccess">✅ Successfully saved.</div>

    <div id="tournament-end" class="d-none" role="dialog" aria-modal="true" aria-labelledby="endTitle">
      <div class="tournament-end-content">
        <i class="bi bi-trophy-fill trophy-icon" aria-hidden="true"></i>
        <h1 id="endTitle" data-i18n="endTitle">Konec turnaje</h1>
        <p data-i18n="endSubtitle">Všechna kola dokončena</p>
        <button id="restartTournamentBtn" type="button" class="btn btn-primary btn-lg">
          <i class="bi bi-arrow-clockwise" aria-hidden="true"></i> <span data-i18n="restart">Restartovat</span>
        </button>
      </div>
    </div>

    <div id="main-content">
      <div id="round-indicator" aria-live="polite">Round 1 / 15</div>
      <div id="clock" role="timer" aria-live="off">00:00</div>
      <div id="blinds">
        <div id="blinds-combined">100 / 200</div>
        <div id="ante">Ante: 200</div>
      </div>
      <div id="next-blinds" aria-live="polite">Next: 200 / 400</div>
    </div>

    <div id="progressBarContainer" role="progressbar" aria-label="Round progress">
      <div id="progressBar"></div>
    </div>

    <button id="openForm" type="button" class="bi bi-gear-fill icon-button settings-button" title="Nastavení" aria-label="Nastavení"></button>
    <button id="playPauseToggle" type="button" class="bi bi-play-circle-fill icon-button pause-button" title="Spustit (mezerník)" aria-label="Spustit (mezerník)"></button>
    <button id="fullscreenToggle" type="button" class="bi bi-arrows-fullscreen icon-button fullscreen-button" title="Celá obrazovka" aria-label="Celá obrazovka"></button>
    <button id="langToggle" class="lang-toggle" type="button" title="Přepnout jazyk / Switch language" aria-label="Přepnout jazyk / Switch language">CZ</button>

    <div class="modal fade" id="blindForm" tabindex="-1" aria-labelledby="blindFormTitle" aria-hidden="true">
      <div class="modal-dialog modal-fullscreen">
        <div class="modal-content text-white bg-dark">

          <div class="modal-header border-0 flex-wrap flex-md-nowrap justify-content-between align-items-center">
            <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center gap-2 gap-md-4">
              <h1 class="modal-title mb-0" id="blindFormTitle" data-i18n="modalTitle">Set your rounds</h1>
              <div class="d-flex align-items-center gap-3">
                <p id="roundCountDisplay" class="mb-0 text-secondary"></p>

                <button id="resetDefaultsBtn" type="button" class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1" title="">
                  <i class="bi bi-arrow-counterclockwise" aria-hidden="true"></i> <span data-i18n="reset">Reset</span>
                </button>
              </div>
            </div>

            <div class="d-flex align-items-center gap-4 mt-3 mt-md-0">
              <button id="saveBlinds" type="button" class="btn btn-primary fw-bold px-4 py-2 d-flex align-items-center gap-2" style="border-radius: 0.5rem; transition: all 0.2s;">
                <i class="bi bi-check2-circle fs-5" aria-hidden="true"></i> <span data-i18n="saveAndConfirm">Save and Confirm</span>
              </button>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
          </div>

          <div class="modal-body overflow-auto">
            <div id="validationMessage" class="alert alert-danger d-none" role="alert" aria-live="assertive"></div>

            <form id="blindFormElement">
              <div class="container">

                <div class="mb-5 mt-2 p-4 rounded" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
                  <label class="form-label text-info fw-bold mb-3" for="globalTimeInput" data-i18n="globalTimeLabel">Set time for all rounds (minutes)</label>
                  <div class="input-group">
                    <input type="number" id="globalTimeInput" class="form-control text-center bg-dark text-white" min="1" value="10" />
                    <button id="applyGlobalTimeBtn" type="button" class="btn btn-info text-white fw-bold px-4" data-i18n="useForAll">Use for all</button>
                  </div>
                </div>

                <div class="row g-4">
                  <div class="col-12" id="rounds-container"></div>
                </div>

              </div>
            </form>

            <footer id="bottom-controls" class="d-none">
              <button id="addRoundBtn" type="button" class="btn btn-outline-success">
                ➕ <span data-i18n="addRound">Add a new round</span>
              </button>
              <button id="addPauseBtn" type="button" class="btn btn-outline-warning">
                ⏸️ <span data-i18n="addPause">Add a pause</span>
              </button>
            </footer>
          </div>
        </div>
      </div>
    </div>

    <audio id="transitionSound" src="/sounds/honk.mp3" preload="auto"></audio>
    <div id="flashOverlay" aria-hidden="true"></div>
  </div>

  <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</Layout>

<script>
  // === TYPY ===
  type RoundData =
    | { isPause: true; time: number }
    | { isPause: false; smallBlind: number; bigBlind: number; time: number };

  type StoredConfig = {
    version: number;
    data: RoundData[];
  };

  type Lang = "cs" | "en";

  // === KONSTANTY ===
  const STORAGE_KEY = "pokerTimerRounds";
  const STORAGE_VERSION = 1;
  const LANG_STORAGE_KEY = "pokerTimerLang";
  const DEFAULT_ROUND_SECONDS = 600;
  const TIMER_TICK_MS = 250;
  const NEXT_BLIND_THRESHOLD = 0.2; // posledních 20 %

  // === PŘEKLADY ===
  const translations: Record<Lang, Record<string, string>> = {
    cs: {
      saveSuccess: "✅ Úspěšně uloženo.",
      modalTitle: "Nastavení kol",
      reset: "Reset",
      saveAndConfirm: "Uložit a potvrdit",
      globalTimeLabel: "Nastavit čas pro všechna kola (minuty)",
      useForAll: "Použít pro všechna",
      addRound: "Přidat kolo",
      addPause: "Přidat pauzu",
      smallBlind: "Small Blind",
      bigBlind: "Big Blind",
      timeMinutes: "Čas (minuty)",
      pause: "Pauza",
      round: "Kolo",
      totalRounds: "Celkem kol:",
      next: "Další:",
      pauseLabel: "Pauza",
      tournamentEnd: "Konec turnaje",
      endTitle: "Konec turnaje",
      endSubtitle: "Všechna kola dokončena",
      restart: "Restartovat",
      ante: "Ante:",
      settings: "Nastavení",
      startSpace: "Spustit (mezerník)",
      pauseSpace: "Pozastavit (mezerník)",
      fullscreen: "Celá obrazovka",
      close: "Zavřít",
      delete: "Smazat kolo",
      resetConfirm: "Opravdu chcete vymazat aktuální nastavení a vrátit výchozí strukturu kol? (Změny se trvale uloží až po kliknutí na Uložit)",
      validationError: "Zkontroluj zvýrazněná pole. Čas musí být alespoň 1 minuta a big blind nesmí být menší než small blind.",
    },
    en: {
      saveSuccess: "✅ Successfully saved.",
      modalTitle: "Set your rounds",
      reset: "Reset",
      saveAndConfirm: "Save and Confirm",
      globalTimeLabel: "Set time for all rounds (minutes)",
      useForAll: "Use for all",
      addRound: "Add a new round",
      addPause: "Add a pause",
      smallBlind: "Small Blind",
      bigBlind: "Big Blind",
      timeMinutes: "Time (minutes)",
      pause: "Pause",
      round: "Round",
      totalRounds: "Total rounds:",
      next: "Next:",
      pauseLabel: "Pause",
      tournamentEnd: "Tournament end",
      endTitle: "Tournament end",
      endSubtitle: "All rounds completed",
      restart: "Restart",
      ante: "Ante:",
      settings: "Settings",
      startSpace: "Start (space)",
      pauseSpace: "Pause (space)",
      fullscreen: "Fullscreen",
      close: "Close",
      delete: "Delete round",
      resetConfirm: "Really clear current configuration and restore default rounds? (Changes are saved permanently only after clicking Save)",
      validationError: "Check the highlighted fields. Time must be at least 1 minute and the big blind can't be smaller than the small blind.",
    },
  };

  let currentLang: Lang = (localStorage.getItem(LANG_STORAGE_KEY) as Lang) || "cs";

  function t(key: string): string {
    return translations[currentLang][key] || key;
  }

  // === GLOBÁLNÍ PROMĚNNÉ ===
  let timerInterval: number | undefined;
  let currentRound = 0;
  let roundSecondsLeft = DEFAULT_ROUND_SECONDS;
  let totalRoundSeconds = DEFAULT_ROUND_SECONDS;
  let isTimerRunning = false;
  let expectedEndTime = 0;
  let wakeLock: any = null;
  let tournamentEnded = false;
  let rowUidCounter = 0; // pro unikátní id řádků (fix kolize id po smazání)

  // === HELPER FUNKCE ===
  function formatTime(seconds: number): string {
    const minutes = Math.floor(seconds / 60);
    const remainingSeconds = seconds % 60;
    return `${String(minutes).padStart(2, "0")}:${String(remainingSeconds).padStart(2, "0")}`;
  }

  function getInput(id: string): HTMLInputElement | null {
    return document.getElementById(id) as HTMLInputElement | null;
  }

  function setControlLabel(el: HTMLElement | null, text: string) {
    el?.setAttribute("title", text);
    el?.setAttribute("aria-label", text);
  }

  // === WAKE LOCK ===
  async function requestWakeLock() {
    try {
      if ("wakeLock" in navigator) {
        wakeLock = await (navigator as any).wakeLock.request("screen");
      }
    } catch (err) {
      console.log("Wake Lock nelze aktivovat", err);
    }
  }

  function releaseWakeLock() {
    if (wakeLock !== null) {
      wakeLock.release().catch(console.error);
      wakeLock = null;
    }
  }

  // Re-acquire wake lock po návratu z pozadí
  document.addEventListener("visibilitychange", async () => {
    if (document.visibilityState === "visible" && isTimerRunning && wakeLock === null) {
      await requestWakeLock();
    }
  });

  // === TIMER ===
  function updateProgressBar() {
    const progressBar = document.getElementById("progressBar") as HTMLDivElement | null;
    if (!progressBar || totalRoundSeconds <= 0) return;

    const percent = Math.max(0, (roundSecondsLeft / totalRoundSeconds) * 100);
    progressBar.style.width = `${percent}%`;
    progressBar.classList.remove("bg-success", "bg-warning", "bg-danger");

    if (percent > 66) progressBar.classList.add("bg-success");
    else if (percent > 33) progressBar.classList.add("bg-warning");
    else progressBar.classList.add("bg-danger");
  }

  async function startTimer() {
    if (tournamentEnded) return;

    // Pojistka proti dvojitému intervalu
    if (timerInterval !== undefined) {
      clearInterval(timerInterval);
      timerInterval = undefined;
    }

    const clock = document.getElementById("clock");
    const playPauseBtn = document.getElementById("playPauseToggle");

    isTimerRunning = true;
    playPauseBtn?.classList.replace("bi-play-circle-fill", "bi-pause-circle-fill");
    setControlLabel(playPauseBtn, t("pauseSpace"));

    await requestWakeLock();

    expectedEndTime = Date.now() + roundSecondsLeft * 1000;

    timerInterval = window.setInterval(() => {
      const remainingMs = expectedEndTime - Date.now();
      roundSecondsLeft = Math.max(0, Math.round(remainingMs / 1000));

      // Next blind preview v posledních 20 %
      const nextBlindsDisplay = document.getElementById("next-blinds");
      if (nextBlindsDisplay && totalRoundSeconds > 0) {
        if (roundSecondsLeft / totalRoundSeconds <= NEXT_BLIND_THRESHOLD) {
          nextBlindsDisplay.classList.add("show");
        }
      }

      if (remainingMs <= 0) {
        roundSecondsLeft = 0;
        if (clock) clock.textContent = formatTime(0);
        updateProgressBar();
        advanceToNextRound();
        return;
      }

      if (clock) clock.textContent = formatTime(roundSecondsLeft);
      updateProgressBar();
    }, TIMER_TICK_MS);
  }

  function stopTimer() {
    const playPauseBtn = document.getElementById("playPauseToggle");
    isTimerRunning = false;
    clearInterval(timerInterval);
    timerInterval = undefined;

    releaseWakeLock();

    playPauseBtn?.classList.replace("bi-pause-circle-fill", "bi-play-circle-fill");
    setControlLabel(playPauseBtn, t("startSpace"));

    const progressBar = document.getElementById("progressBar") as HTMLDivElement | null;
    if (progressBar) {
      progressBar.classList.remove("bg-success", "bg-warning", "bg-danger");
      progressBar.classList.add("bg-primary");
    }
  }

  function toggleTimer() {
    if (tournamentEnded) return;

    if (!isTimerRunning) {
      const audio = document.getElementById("transitionSound") as HTMLAudioElement | null;
      if (audio && audio.currentTime === 0) {
        audio.play().then(() => audio.pause()).catch(() => {});
      }

      if (roundSecondsLeft <= 0) {
        setRound(currentRound);
      }
      startTimer();
    } else {
      stopTimer();
    }
  }

  function advanceToNextRound() {
    stopTimer();

    const rounds = document.querySelectorAll("#rounds-container .round-row");
    const audio = document.getElementById("transitionSound") as HTMLAudioElement | null;
    const overlay = document.getElementById("flashOverlay");

    if (audio) {
      audio.currentTime = 0;
      audio.play().catch((e) => console.log("Audio zablokováno prohlížečem", e));
    }
    if (overlay) {
      overlay.classList.remove("flash-blink");
      void overlay.offsetWidth;
      overlay.classList.add("flash-blink");
    }

    if (currentRound + 1 >= rounds.length) {
      showTournamentEnd();
      return;
    }

    currentRound++;
    setRound(currentRound);
    startTimer();
  }

  function showTournamentEnd() {
    tournamentEnded = true;
    const endScreen = document.getElementById("tournament-end");
    const mainContent = document.getElementById("main-content");
    const progressBar = document.getElementById("progressBarContainer");
    const playPause = document.getElementById("playPauseToggle");

    endScreen?.classList.remove("d-none");
    mainContent?.classList.add("d-none");
    progressBar?.classList.add("d-none");
    playPause?.classList.add("d-none");
  }

  function hideTournamentEnd() {
    tournamentEnded = false;
    document.getElementById("tournament-end")?.classList.add("d-none");
    document.getElementById("main-content")?.classList.remove("d-none");
    document.getElementById("progressBarContainer")?.classList.remove("d-none");
    document.getElementById("playPauseToggle")?.classList.remove("d-none");
  }

  function restartTournament() {
    hideTournamentEnd();
    currentRound = 0;
    setRound(0);
    const clock = document.getElementById("clock");
    if (clock) clock.textContent = formatTime(roundSecondsLeft);
  }

  function setRoundSeconds(seconds: number) {
    roundSecondsLeft = seconds;
    totalRoundSeconds = seconds;
  }

  // === BLINDS RENDERING ===
  function createStandardRound(i: number, customSmall?: number, customBig?: number, customTime?: number) {
    const container = document.getElementById("rounds-container");
    if (!container) return;

    const row = document.createElement("div");
    row.className = "round-row mb-4";

    // Hodnoty bezpečně přetypujeme na čísla (i kdyby v localStorage byl nesmysl)
    const smallBlindValue = Number(customSmall !== undefined ? customSmall : i * 100) || 0;
    const bigBlindValue = Number(customBig !== undefined ? customBig : smallBlindValue * 2) || 0;
    const defaultTime = Number(customTime !== undefined ? customTime : 10) || 10;

    // Unikátní id pro řádek – řeší kolizi id po smazání kola
    const uid = `r${rowUidCounter++}`;
    const smallId = `small_${uid}`;
    const bigId = `big_${uid}`;
    const timeId = `time_${uid}`;

    row.innerHTML = `
      <div class="round-column">
        <label class="form-label round-label" for="${smallId}">${t("round")} ${i} – ${t("smallBlind")}</label>
        <div class="input-group">
          <button class="btn btn-outline-light btn-blind-decr" type="button" data-target="${smallId}" data-delta="-100" aria-label="-100">-100</button>
          <input type="number" class="form-control text-center" id="${smallId}" step="100" min="0" value="${smallBlindValue}" aria-label="${t("round")} ${i} ${t("smallBlind")}" />
          <button class="btn btn-outline-light btn-blind-incr" type="button" data-target="${smallId}" data-delta="100" aria-label="+100">+100</button>
        </div>
      </div>
      <div class="round-column">
        <label class="form-label big-label" for="${bigId}">${t("bigBlind")}</label>
        <div class="input-group">
          <button class="btn btn-outline-light btn-blind-decr" type="button" data-target="${bigId}" data-delta="-100" aria-label="-100">-100</button>
          <input type="number" class="form-control text-center" id="${bigId}" step="100" min="0" value="${bigBlindValue}" aria-label="${t("round")} ${i} ${t("bigBlind")}" />
          <button class="btn btn-outline-light btn-blind-incr" type="button" data-target="${bigId}" data-delta="100" aria-label="+100">+100</button>
        </div>
      </div>
      <div class="round-column">
        <label class="form-label time-label" for="${timeId}">${t("timeMinutes")}</label>
        <div class="input-group">
          <input type="number" class="form-control text-center" id="${timeId}" min="1" value="${defaultTime}" aria-label="${t("round")} ${i} ${t("timeMinutes")}" />
          <button type="button" class="btn btn-outline-danger btn-delete-row" title="${t("delete")}" aria-label="${t("delete")}">🗑️</button>
        </div>
      </div>
    `;
    container.appendChild(row);
  }

  function createPauseRound(customTime?: number) {
    const container = document.getElementById("rounds-container");
    if (!container) return;

    const pauseRow = document.createElement("div");
    pauseRow.className = "round-row mb-4";
    pauseRow.setAttribute("data-pause", "true");
    const pauseId = `pause${Date.now()}${Math.random().toString(36).slice(2, 5)}`;
    const timeValue = Number(customTime !== undefined ? customTime : 10) || 10;

    pauseRow.innerHTML = `
      <div class="round-column">
        <label class="form-label pause-name-label">${t("pause")}</label>
      </div>
      <div class="round-column"></div>
      <div class="round-column">
        <label class="form-label pause-time-label" for="${pauseId}">${t("timeMinutes")}</label>
        <div class="input-group">
          <input type="number" class="form-control text-center" id="${pauseId}" min="1" value="${timeValue}" aria-label="${t("pause")} ${t("timeMinutes")}" />
          <button type="button" class="btn btn-outline-danger btn-delete-row" title="${t("delete")}" aria-label="${t("delete")}">🗑️</button>
        </div>
      </div>
    `;
    container.appendChild(pauseRow);
  }

  function saveRoundsToStorage() {
    const rows = document.querySelectorAll("#rounds-container .round-row");
    const roundsData: RoundData[] = [];

    rows.forEach((row) => {
      const isPause = row.hasAttribute("data-pause");
      if (isPause) {
        const pauseInput = row.querySelector("input[type=number]") as HTMLInputElement;
        roundsData.push({ isPause: true, time: Number(pauseInput?.value) || 10 });
      } else {
        const smallBlind = row.querySelector("input[id^='small']") as HTMLInputElement;
        const bigBlind = row.querySelector("input[id^='big']") as HTMLInputElement;
        const timeInput = row.querySelector("input[id^='time']") as HTMLInputElement;
        roundsData.push({
          isPause: false,
          smallBlind: Number(smallBlind?.value) || 0,
          bigBlind: Number(bigBlind?.value) || 0,
          time: Number(timeInput?.value) || 10,
        });
      }
    });

    const config: StoredConfig = { version: STORAGE_VERSION, data: roundsData };
    localStorage.setItem(STORAGE_KEY, JSON.stringify(config));
  }

  function loadRoundsFromStorage(): RoundData[] | null {
    const raw = localStorage.getItem(STORAGE_KEY);
    if (!raw) return null;
    try {
      const parsed = JSON.parse(raw) as StoredConfig | RoundData[];
      // Backward compatibility — pokud je to starý formát (array bez version), použij ho
      if (Array.isArray(parsed)) {
        return parsed;
      }
      if (parsed && parsed.version === STORAGE_VERSION && Array.isArray(parsed.data)) {
        return parsed.data;
      }
      console.warn("Nekompatibilní verze localStorage, použiji defaults");
      return null;
    } catch (e) {
      console.error("Chyba při načítání z localStorage", e);
      return null;
    }
  }

  function generateDefaultRounds() {
    for (let i = 1; i <= 15; i++) {
      createStandardRound(i);
      if (i === 6 || i === 12) {
        createPauseRound();
      }
    }
  }

  function resetToDefaults() {
    const isConfirmed = confirm(t("resetConfirm"));
    if (!isConfirmed) return;

    const container = document.getElementById("rounds-container");
    if (!container) return;
    clearValidation();
    container.innerHTML = "";
    generateDefaultRounds();
    updateRoundCountDisplay();
  }

  function createBlindRounds() {
    const container = document.getElementById("rounds-container");
    if (!container) return;
    container.innerHTML = "";

    const savedData = loadRoundsFromStorage();

    if (savedData && savedData.length > 0) {
      let roundIndex = 1;
      savedData.forEach((data) => {
        if (data.isPause) {
          createPauseRound(data.time);
        } else {
          createStandardRound(roundIndex, data.smallBlind, data.bigBlind, data.time);
          roundIndex++;
        }
      });
    } else {
      generateDefaultRounds();
    }

    updateRoundCountDisplay();
  }

  function addNewRound() {
    // Index jen pro výpočet defaultních blindů a label – id je už unikátní
    const standardCount = getTotalNonPauseRounds();
    createStandardRound(standardCount + 1);
    reindexRounds();
    updateRoundCountDisplay();
  }

  function addNewPause() {
    createPauseRound();
    reindexRounds();
    updateRoundCountDisplay();
  }

  function applyGlobalTime() {
    const globalInput = getInput("globalTimeInput");
    if (!globalInput) return;
    const minutes = Number(globalInput.value);
    if (Number.isNaN(minutes) || minutes < 1) return;
    const inputs = document.querySelectorAll("#rounds-container input[id^=time], #rounds-container input[id^=pause]");
    inputs.forEach((input) => {
      (input as HTMLInputElement).value = minutes.toString();
    });
  }

  function reindexRounds() {
    const rows = document.querySelectorAll("#rounds-container .round-row");
    let roundNumber = 1;

    rows.forEach((row) => {
      const isPause = row.hasAttribute("data-pause");
      if (isPause) {
        // Re-translate statické labely pauzy při změně jazyka
        const nameLabel = row.querySelector(".pause-name-label");
        if (nameLabel) nameLabel.textContent = t("pause");
        const pauseTimeLabel = row.querySelector(".pause-time-label");
        if (pauseTimeLabel) pauseTimeLabel.textContent = t("timeMinutes");
      } else {
        const label = row.querySelector(".round-label");
        if (label) {
          label.textContent = `${t("round")} ${roundNumber} – ${t("smallBlind")}`;
        }
        // Re-translate ostatní labely (big blind, čas) při změně jazyka
        const bigLabel = row.querySelector(".big-label");
        if (bigLabel) bigLabel.textContent = t("bigBlind");
        const timeLabel = row.querySelector(".time-label");
        if (timeLabel) timeLabel.textContent = t("timeMinutes");
        roundNumber++;
      }
    });
    updateRoundCountDisplay();
  }

  function getTotalNonPauseRounds(): number {
    const allRounds = document.querySelectorAll("#rounds-container .round-row");
    let count = 0;
    allRounds.forEach((row) => {
      if (!row.hasAttribute("data-pause")) count++;
    });
    return count;
  }

  function getCurrentRoundNumber(index: number): number {
    // Vrátí pořadí ne-pauzového kola od začátku (1-based), pro pauzu vrátí 0
    const rounds = document.querySelectorAll("#rounds-container .round-row");
    let count = 0;
    for (let i = 0; i <= index && i < rounds.length; i++) {
      if (!rounds[i].hasAttribute("data-pause")) count++;
    }
    return count;
  }

  function updateRoundIndicator(index: number) {
    const indicator = document.getElementById("round-indicator");
    if (!indicator) return;

    const rounds = document.querySelectorAll("#rounds-container .round-row");
    const round = rounds[index];
    if (!round) {
      indicator.textContent = "";
      return;
    }

    const total = getTotalNonPauseRounds();
    if (round.hasAttribute("data-pause")) {
      indicator.textContent = t("pauseLabel");
    } else {
      const num = getCurrentRoundNumber(index);
      indicator.textContent = `${t("round")} ${num} / ${total}`;
    }
  }

  function setRound(index: number) {
    const rounds = document.querySelectorAll("#rounds-container .round-row");
    const round = rounds[index];
    if (!round) return;

    const isPause = round.hasAttribute("data-pause");
    const blindsCombined = document.getElementById("blinds-combined");
    const anteDisplay = document.getElementById("ante");

    let seconds = DEFAULT_ROUND_SECONDS;

    if (isPause) {
      if (blindsCombined) blindsCombined.textContent = t("pauseLabel");
      if (anteDisplay) anteDisplay.textContent = "";
      const pauseInput = round.querySelector("input[type=number]") as HTMLInputElement;
      seconds = (Number(pauseInput?.value) || 10) * 60;
    } else {
      const smallBlind = round.querySelector("input[id^='small']") as HTMLInputElement;
      const bigBlind = round.querySelector("input[id^='big']") as HTMLInputElement;
      const timeInput = round.querySelector("input[id^='time']") as HTMLInputElement;

      if (smallBlind && bigBlind && blindsCombined) {
        blindsCombined.textContent = `${smallBlind.value} / ${bigBlind.value}`;
      }
      if (anteDisplay && bigBlind) {
        anteDisplay.textContent = `${t("ante")} ${bigBlind.value}`;
      }
      seconds = (Number(timeInput?.value) || 10) * 60;
    }

    setRoundSeconds(seconds);
    updateRoundIndicator(index);

    // Next blind preview
    const nextBlindsDisplay = document.getElementById("next-blinds");
    const nextRound = rounds[index + 1];
    if (nextBlindsDisplay) {
      nextBlindsDisplay.classList.remove("show");
      if (nextRound) {
        const isNextPause = nextRound.hasAttribute("data-pause");
        if (isNextPause) {
          nextBlindsDisplay.textContent = `${t("next")} ${t("pauseLabel")}`;
        } else {
          const nextSmall = nextRound.querySelector("input[id^='small']") as HTMLInputElement;
          const nextBig = nextRound.querySelector("input[id^='big']") as HTMLInputElement;
          if (nextSmall && nextBig) {
            nextBlindsDisplay.textContent = `${t("next")} ${nextSmall.value} / ${nextBig.value}`;
          }
        }
      } else {
        nextBlindsDisplay.textContent = `${t("next")} ${t("tournamentEnd")}`;
      }
    }
  }

  function updateRoundCountDisplay() {
    const display = document.getElementById("roundCountDisplay");
    if (!display) return;
    display.textContent = `${t("totalRounds")} ${getTotalNonPauseRounds()}`;
  }

  // === VALIDACE VSTUPŮ ===
  function clearValidation() {
    document.querySelectorAll("#rounds-container .is-invalid")
      .forEach((el) => el.classList.remove("is-invalid"));
    document.getElementById("validationMessage")?.classList.add("d-none");
  }

  function markInvalid(el: HTMLInputElement | null) {
    el?.classList.add("is-invalid");
  }

  function validateRounds(): boolean {
    clearValidation();
    let valid = true;
    const rows = document.querySelectorAll("#rounds-container .round-row");

    rows.forEach((row) => {
      const isPause = row.hasAttribute("data-pause");

      if (isPause) {
        const timeInput = row.querySelector("input[id^='pause']") as HTMLInputElement;
        const time = Number(timeInput?.value);
        if (!timeInput?.value || Number.isNaN(time) || time < 1) {
          markInvalid(timeInput);
          valid = false;
        }
      } else {
        const small = row.querySelector("input[id^='small']") as HTMLInputElement;
        const big = row.querySelector("input[id^='big']") as HTMLInputElement;
        const timeInput = row.querySelector("input[id^='time']") as HTMLInputElement;
        const sV = Number(small?.value);
        const bV = Number(big?.value);
        const tV = Number(timeInput?.value);

        if (small?.value === "" || Number.isNaN(sV) || sV < 0) { markInvalid(small); valid = false; }
        if (big?.value === "" || Number.isNaN(bV) || bV < 0) { markInvalid(big); valid = false; }
        if (!Number.isNaN(sV) && !Number.isNaN(bV) && bV < sV) { markInvalid(big); valid = false; }
        if (!timeInput?.value || Number.isNaN(tV) || tV < 1) { markInvalid(timeInput); valid = false; }
      }
    });

    if (!valid) {
      const msg = document.getElementById("validationMessage");
      if (msg) {
        msg.textContent = "❌ " + t("validationError");
        msg.classList.remove("d-none");
      }
    }
    return valid;
  }

  // === MODAL ===
  function openForm() {
    const modalElement = document.getElementById("blindForm");
    if (modalElement && (window as any).bootstrap) {
      new (window as any).bootstrap.Modal(modalElement).show();
    }
  }

  function saveBlinds() {
    const roundElements = document.querySelectorAll("#rounds-container .round-row");
    if (roundElements.length === 0) return;

    // Validace – při chybě nic neukládáme a modal necháme otevřený
    if (!validateRounds()) return;

    // Reset stavu (ale timer NESPOUŠTÍME – pustí ho uživatel přes play)
    stopTimer();
    hideTournamentEnd();
    currentRound = 0;
    setRound(0);

    const clockElement = document.getElementById("clock");
    if (clockElement) clockElement.textContent = formatTime(roundSecondsLeft);

    saveRoundsToStorage();
    showSaveMessage();

    const modal = document.getElementById("blindForm");
    if (modal && (window as any).bootstrap) {
      (window as any).bootstrap.Modal.getInstance(modal)?.hide();
    }
  }

  function showSaveMessage() {
    const message = document.getElementById("saveMessage");
    if (!message) return;
    message.classList.remove("d-none");
    message.style.opacity = "1";
    setTimeout(() => {
      message.style.opacity = "0";
      setTimeout(() => message.classList.add("d-none"), 300);
    }, 3000);
  }

  function initLoader() {
    setTimeout(() => {
      document.querySelector(".poker-timer-app")?.classList.add("loaded");
      const loader = document.getElementById("loader");
      if (loader) {
        loader.style.opacity = "0";
        loader.style.visibility = "hidden";
      }
    }, 500);
  }

  // === JAZYK ===
  function applyLanguage() {
    // Atribut lang na <html> kvůli přístupnosti / čtečkám
    document.documentElement.lang = currentLang;

    // Statické texty s data-i18n
    document.querySelectorAll("[data-i18n]").forEach((el) => {
      const key = el.getAttribute("data-i18n");
      if (key) el.textContent = t(key);
    });

    // Titulky / aria-labely tlačítek
    setControlLabel(document.getElementById("openForm"), t("settings"));
    setControlLabel(document.getElementById("playPauseToggle"), isTimerRunning ? t("pauseSpace") : t("startSpace"));
    setControlLabel(document.getElementById("fullscreenToggle"), t("fullscreen"));
    document.getElementById("resetDefaultsBtn")?.setAttribute("title", t("reset"));

    // Tlačítko jazyka
    const langBtn = document.getElementById("langToggle");
    if (langBtn) langBtn.textContent = currentLang === "cs" ? "EN" : "CZ";

    // Překreslení labelů kol s novými překlady (hodnoty zůstanou)
    reindexRounds();

    // Aktualizace aktuálního kola na hlavní obrazovce
    if (!tournamentEnded) {
      const rounds = document.querySelectorAll("#rounds-container .round-row");
      if (rounds.length > 0) {
        setRound(currentRound);
      }
    }
  }

  function toggleLanguage() {
    currentLang = currentLang === "cs" ? "en" : "cs";
    localStorage.setItem(LANG_STORAGE_KEY, currentLang);
    applyLanguage();
  }

  // === INICIALIZACE ===
  initLoader();
  createBlindRounds();
  applyLanguage();

  const openFormBtn = document.getElementById("openForm");
  const saveBlindsBtn = document.getElementById("saveBlinds");
  const applyGlobalTimeBtn = document.getElementById("applyGlobalTimeBtn");
  const playPauseToggle = document.getElementById("playPauseToggle");
  const addRoundBtn = document.getElementById("addRoundBtn");
  const addPauseBtn = document.getElementById("addPauseBtn");
  const blindForm = document.getElementById("blindForm");
  const bottomControls = document.getElementById("bottom-controls");
  const resetDefaultsBtn = document.getElementById("resetDefaultsBtn");
  const langToggleBtn = document.getElementById("langToggle");
  const restartBtn = document.getElementById("restartTournamentBtn");
  const fullscreenToggle = document.getElementById("fullscreenToggle");
  const roundsContainer = document.getElementById("rounds-container");

  openFormBtn?.addEventListener("click", openForm);
  saveBlindsBtn?.addEventListener("click", saveBlinds);
  applyGlobalTimeBtn?.addEventListener("click", applyGlobalTime);
  playPauseToggle?.addEventListener("click", toggleTimer);
  addRoundBtn?.addEventListener("click", addNewRound);
  addPauseBtn?.addEventListener("click", addNewPause);
  resetDefaultsBtn?.addEventListener("click", resetToDefaults);
  langToggleBtn?.addEventListener("click", toggleLanguage);
  restartBtn?.addEventListener("click", restartTournament);

  // Event delegation pro tlačítka v řádcích (místo onclick atributů)
  roundsContainer?.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (!target) return;

    // -100 / +100 tlačítka
    if (target.classList.contains("btn-blind-decr") || target.classList.contains("btn-blind-incr")) {
      const inputId = target.getAttribute("data-target");
      const delta = Number(target.getAttribute("data-delta") || "0");
      if (inputId) {
        const input = getInput(inputId);
        if (input) {
          const current = Number(input.value) || 0;
          input.value = Math.max(0, current + delta).toString();
          input.classList.remove("is-invalid");
        }
      }
    }

    // Smazat řádek
    if (target.classList.contains("btn-delete-row")) {
      target.closest(".round-row")?.remove();
      reindexRounds();
      updateRoundCountDisplay();
    }
  });

  // Při úpravě hodnoty zruš červené zvýraznění
  roundsContainer?.addEventListener("input", (e) => {
    const target = e.target as HTMLElement;
    if (target && target.classList.contains("is-invalid")) {
      target.classList.remove("is-invalid");
    }
  });

  if (blindForm && bottomControls) {
    blindForm.addEventListener("show.bs.modal", () => {
      bottomControls.classList.remove("d-none");
      clearValidation();
    });
    blindForm.addEventListener("hide.bs.modal", () => {
      bottomControls.classList.add("d-none");
    });
  }

  // === FULLSCREEN ===
  function toggleFullscreen() {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch((err) => console.log(err));
    } else {
      if (document.exitFullscreen) document.exitFullscreen();
    }
  }

  fullscreenToggle?.addEventListener("click", toggleFullscreen);

  document.addEventListener("fullscreenchange", () => {
    const nav = document.querySelector(".main-nav") as HTMLElement;
    if (document.fullscreenElement) {
      if (nav) nav.style.display = "none";
      fullscreenToggle?.classList.replace("bi-arrows-fullscreen", "bi-fullscreen-exit");
    } else {
      if (nav) nav.style.display = "flex";
      fullscreenToggle?.classList.replace("bi-fullscreen-exit", "bi-arrows-fullscreen");
    }
  });

  // === KLÁVESOVÉ ZKRATKY ===
  document.addEventListener("keydown", (e) => {
    if (e.code !== "Space") return;

    // Neaktivovat, pokud uživatel píše do inputu
    const target = e.target as HTMLElement | null;
    const tag = target?.tagName;
    if (tag === "INPUT" || tag === "TEXTAREA" || tag === "SELECT" || tag === "BUTTON") return;

    // Neaktivovat, pokud je otevřený modal
    if (blindForm?.classList.contains("show")) return;

    e.preventDefault();
    toggleTimer();
  });

  const clockElement = document.getElementById("clock");
  if (clockElement) clockElement.textContent = formatTime(DEFAULT_ROUND_SECONDS);
</script>

