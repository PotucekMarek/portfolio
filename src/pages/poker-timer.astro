---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Poker Timer">
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet" />

  <div class="poker-timer-app">
    <div id="loader">
      <img src="/chip.png" alt="Loading..." />
    </div>

    <div class="icon-wrapper top-left"><i class="bi bi-suit-heart big-icon"></i></div>
    <div class="icon-wrapper top-right"><i class="bi bi-suit-diamond big-icon"></i></div>
    <div class="icon-wrapper bottom-left"><i class="bi bi-suit-club big-icon"></i></div>
    <div class="icon-wrapper bottom-right"><i class="bi bi-suit-spade big-icon"></i></div>

    <div id="saveMessage" class="alert alert-success d-none" role="alert">✅ Successufuly saved.</div>

    <div id="main-content">
      <div id="clock">00:00</div>
      <div id="blinds">
        <div id="blinds-combined">100 / 200</div>
        <div id="ante">Ante: 200</div>
      </div>
      <div id="next-blinds">Next: 200 / 400</div>
    </div>

    <div id="progressBarContainer">
      <div id="progressBar"></div>
    </div>

    <i id="openForm" class="bi bi-gear-fill icon-button settings-button" title="Nastavení"></i>
    <i id="playPauseToggle" class="bi bi-play-circle-fill icon-button pause-button" title="Spustit (mezerník)"></i>
    <i id="fullscreenToggle" class="bi bi-arrows-fullscreen icon-button fullscreen-button" title="Celá obrazovka"></i>

    <div class="modal fade" id="blindForm" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-fullscreen">
        <div class="modal-content text-white bg-dark">
          <div class="modal-header border-0 flex-wrap flex-md-nowrap justify-content-between align-items-center">
            <div class="d-flex flex-column flex-md-row align-items-start gap-2">
              <h1 class="modal-title mb-0">Set your rounds</h1>
              <p id="roundCountDisplay" class="mb-0">Total rounds created: 12</p>
            </div>
          
            <div class="d-flex align-items-center gap-3 mt-3 mt-md-0">
              <button id="saveBlinds" type="button" class="btn btn-outline-light save-icon-btn" title="Uložit změny">
                <i class="bi bi-save-fill"></i>
              </button>
              <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Zavřít"></button>
            </div>
          </div>

          <div class="modal-body overflow-auto">
            <form id="blindFormElement">
              <div class="container">
                <div class="row g-4">
                  <div class="col-12 col-md-6" id="rounds-container"></div>
                </div>
              
                <div class="mb-4 mt-4">
                  <label class="form-label">Set time for all rounds</label>
                  <div class="input-group">
                    <input type="number" id="globalTimeInput" class="form-control text-center" min="1" value="10" />
                    <button id="applyGlobalTimeBtn" type="button" class="btn btn-outline-primary">Use for all</button>
                  </div>
                </div>
              </div>
            </form>

            <footer id="bottom-controls" class="d-none">
              <button id="addRoundBtn" type="button" class="btn btn-outline-success">
                ➕ Add a new round
              </button>
              <button id="addPauseBtn" type="button" class="btn btn-outline-warning">
                ⏸️ Add a pause
              </button>
            </footer>
          </div>  
        </div>
      </div>
    </div> 

    <audio id="transitionSound" src="/sounds/honk.mp3" preload="auto"></audio>
    <div id="flashOverlay"></div>
  </div>
  
  <script is:inline src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</Layout>

<script>
  // === GLOBÁLNÍ PROMĚNNÉ ===
  declare const bootstrap: any;
  let timerInterval: number | undefined;
  let currentRound = 0;
  let roundSecondsLeft = 600; // 10 minut
  let totalRoundSeconds = 600;
  let isTimerRunning = false;

  // === TIMER FUNKCE ===
  let expectedEndTime = 0; // Nová proměnná pro přesný výpočet
  let wakeLock: any = null; // Pro udržení rozsvíceného displeje

  // === TIMER FUNKCE ===
async function startTimer() {
    const clock = document.getElementById("clock");
    const playPauseBtn = document.getElementById("playPauseToggle");

    isTimerRunning = true;
    playPauseBtn?.classList.replace("bi-play-circle-fill", "bi-pause-circle-fill");
    playPauseBtn?.setAttribute("title", "Pozastavit (mezerník)");

    // Žádost o udržení displeje (Wake Lock)
    try {
      if ('wakeLock' in navigator) {
        wakeLock = await (navigator as any).wakeLock.request('screen');
      }
    } catch (err) {
      console.log('Wake Lock nelze aktivovat', err);
    }

    // Výpočet, kdy má timer přesně skončit
    expectedEndTime = Date.now() + (roundSecondsLeft * 1000);

    timerInterval = window.setInterval(() => {
      // Místo odčítání vteřin kontrolujeme reálný čas
      const now = Date.now();
      const remainingMs = expectedEndTime - now;
      roundSecondsLeft = Math.ceil(remainingMs / 1000);

      // === LOGIKA PRO ZOBRAZENÍ NEXT BLIND ===
      const nextBlindsDisplay = document.getElementById("next-blinds");
      if (nextBlindsDisplay && totalRoundSeconds > 0) {
        // Zobrazí se, když zbývá 20 % nebo méně času (80 % uplynulo)
        if ((roundSecondsLeft / totalRoundSeconds) <= 0.2) {
          nextBlindsDisplay.classList.add("show");
        }
      }
      // ======================================

      if (roundSecondsLeft <= 0) {
        roundSecondsLeft = 0;
        if (clock) clock.textContent = formatTime(roundSecondsLeft);
        updateProgressBar();
        advanceToNextRound();
        return; // advanceToNextRound timer zastaví nebo nahodí nové kolo
      }
      
      if (clock) clock.textContent = formatTime(roundSecondsLeft);
      updateProgressBar();
    }, 200); // Kontrolujeme častěji (5x za vteřinu) pro plynulejší překreslení
  }

  function stopTimer() {
    const playPauseBtn = document.getElementById("playPauseToggle");
    isTimerRunning = false;
    clearInterval(timerInterval);

    // Uvolnění displeje
    if (wakeLock !== null) {
      wakeLock.release().catch(console.error);
      wakeLock = null;
    }

    playPauseBtn?.classList.replace("bi-pause-circle-fill", "bi-play-circle-fill");
    playPauseBtn?.setAttribute("title", "Spustit (mezerník)");

    const progressBar = document.getElementById("progressBar") as HTMLDivElement | null;
    if (progressBar) {
      progressBar.classList.remove("bg-success", "bg-warning", "bg-danger");
      progressBar.classList.add("bg-primary");
    }
  }

  function toggleTimer() {
    if (!isTimerRunning) {
      // Vyřešení problému audia na iOS a Androidu (první interakce)
      const audio = document.getElementById("transitionSound") as HTMLAudioElement | null;
      if (audio && audio.currentTime === 0) {
        audio.play().then(() => audio.pause()).catch(() => {});
      }

      if (roundSecondsLeft <= 0) {
        setRound(currentRound); // Nastavení kola, pokud jsme na začátku
      }
      startTimer();
    } else {
      stopTimer();
    }
  }

  function formatTime(seconds: number): string {
    const minutes = Math.floor(seconds / 60);
    const remainingSeconds = seconds % 60;
    return `${String(minutes).padStart(2, "0")}:${String(remainingSeconds).padStart(2, "0")}`;
  }

  function updateProgressBar() {
    const progressBar = document.getElementById("progressBar") as HTMLDivElement | null;
    if (!progressBar || totalRoundSeconds <= 0) return;

    const percent = Math.max(0, (roundSecondsLeft / totalRoundSeconds) * 100);
    progressBar.style.width = `${percent}%`;

    progressBar.classList.remove("bg-success", "bg-warning", "bg-danger");

    if (percent > 66) {
      progressBar.classList.add("bg-success");
    } else if (percent > 33) {
      progressBar.classList.add("bg-warning");
    } else {
      progressBar.classList.add("bg-danger");
    }
  }

function advanceToNextRound() {
    // 1. NEJDŮLEŽITĚJŠÍ: Okamžitě zastavit starý interval, ať se nezblázní!
    stopTimer(); 

    const rounds = document.querySelectorAll("#rounds-container .round-row");
    const audio = document.getElementById("transitionSound") as HTMLAudioElement | null;
    const overlay = document.getElementById("flashOverlay");

    // 2. Vizuální a zvukové efekty
    if (audio) {
        audio.currentTime = 0;
        audio.play().catch(e => console.log("Audio zablokováno prohlížečem", e));
    }
    if (overlay) {
        overlay.classList.remove("flash-blink");
        void overlay.offsetWidth; // Restartuje CSS animaci
        overlay.classList.add("flash-blink");
    }

    // 3. Kontrola, jestli už nejsme na úplném konci (s úpravou indexu, ať to nespadne)
    if (currentRound + 1 >= rounds.length) {
      console.log("Konec kol.");
      return;
    }

    // 4. Nastavení nového kola
    currentRound++;
    setRound(currentRound);

    // 5. Automatické spuštění nového odpočtu
    startTimer();
  }

  function setRoundSeconds(seconds: number) {
    roundSecondsLeft = seconds;
    totalRoundSeconds = seconds;
  }

  // === BLINDS FUNKCE ===
function createStandardRound(i: number, customSmall?: number, customBig?: number, customTime?: number) {
    const container = document.getElementById("rounds-container");
    if (!container) return;

    const row = document.createElement("div");
    row.className = "round-row mb-4";

    // Pokud nemáme uložené hodnoty, použijeme původní výpočet
    const smallBlindValue = customSmall !== undefined ? customSmall : i * 100;
    const bigBlindValue = customBig !== undefined ? customBig : smallBlindValue * 2;
    const defaultTime = customTime !== undefined ? customTime : 10;

    row.innerHTML = `
      <div class="round-column">
        <label class="form-label">Round ${i} – Small Blind</label>
        <div class="input-group">
          <button class="btn btn-outline-light" type="button" onclick="window.adjustBlind('small${i}', -100)">-100</button>
          <input type="number" class="form-control text-center" id="small${i}" step="100" min="0" value="${smallBlindValue}" />
          <button class="btn btn-outline-light" type="button" onclick="window.adjustBlind('small${i}', 100)">+100</button>
        </div>
      </div>
      <div class="round-column">
        <label class="form-label">Big Blind</label>
        <div class="input-group">
          <button class="btn btn-outline-light" type="button" onclick="window.adjustBlind('big${i}', -100)">-100</button>
          <input type="number" class="form-control text-center" id="big${i}" step="100" min="0" value="${bigBlindValue}" />
          <button class="btn btn-outline-light" type="button" onclick="window.adjustBlind('big${i}', 100)">+100</button>
        </div>
      </div>
      <div class="round-column">
        <label class="form-label">Time (minutes)</label>
        <div class="input-group">
          <input type="number" class="form-control text-center" id="time${i}" min="1" value="${defaultTime}" />
          <button type="button" class="btn btn-outline-danger ms-2" onclick="this.closest('.round-row')?.remove(); window.reindexRounds(); window.updateRoundCountDisplay();">
            🗑️
          </button>
        </div>
      </div>
    `;
    container.appendChild(row);
  }

function createPauseRound(customTime?: number) {
    const container = document.getElementById("rounds-container");
    if (!container) return;

    const pauseRow = document.createElement("div");
    pauseRow.className = "round-row mb-4";
    pauseRow.setAttribute("data-pause", "true");
    const pauseId = `pause${Date.now()}`;
    const timeValue = customTime !== undefined ? customTime : 10;

    pauseRow.innerHTML = `
      <div class="round-column">
        <label class="form-label">Pause</label>
      </div>
      <div class="round-column"></div>
      <div class="round-column">
        <label class="form-label">Čas (minuty)</label>
        <div class="input-group">
          <input type="number" class="form-control text-center" id="${pauseId}" min="1" value="${timeValue}" />
          <button type="button" class="btn btn-outline-danger ms-2" onclick="this.closest('.round-row')?.remove(); window.reindexRounds(); window.updateRoundCountDisplay();">
            🗑️
          </button>
        </div>
      </div>
    `;
    container.appendChild(pauseRow);
  }

  function saveRoundsToStorage() {
    const rows = document.querySelectorAll("#rounds-container .round-row");
    const roundsData: any[] = []; // Obejití TS kontroly pro jednoduchost

    rows.forEach(row => {
      const isPause = row.hasAttribute("data-pause");
      if (isPause) {
        const pauseInput = row.querySelector("input[type=number]") as HTMLInputElement;
        roundsData.push({ isPause: true, time: Number(pauseInput?.value) || 10 });
      } else {
        const smallBlind = row.querySelector("input[id^='small']") as HTMLInputElement;
        const bigBlind = row.querySelector("input[id^='big']") as HTMLInputElement;
        const timeInput = row.querySelector("input[id^='time']") as HTMLInputElement;
        roundsData.push({
          isPause: false,
          smallBlind: Number(smallBlind?.value) || 0,
          bigBlind: Number(bigBlind?.value) || 0,
          time: Number(timeInput?.value) || 10
        });
      }
    });

    localStorage.setItem("pokerTimerRounds", JSON.stringify(roundsData));
  }

function createBlindRounds() {
    const container = document.getElementById("rounds-container");
    if (!container) return;
    container.innerHTML = "";

    const savedData = localStorage.getItem("pokerTimerRounds");

    if (savedData) {
      try {
        // Pokud najdeme uložená data, vykreslíme je
        const roundsData = JSON.parse(savedData);
        let roundIndex = 1;
        
        roundsData.forEach((data: any) => {
          if (data.isPause) {
            createPauseRound(data.time);
          } else {
            createStandardRound(roundIndex, data.smallBlind, data.bigBlind, data.time);
            roundIndex++;
          }
        });
      } catch (e) {
        console.error("Chyba při načítání z localStorage", e);
      }
    } else {
      // Pokud nemáme uloženo nic, vygenerujeme výchozí strukturu (staré chování)
      for (let i = 1; i <= 15; i++) {
        createStandardRound(i);
        if (i === 6 || i === 12) {
          createPauseRound();
        }
      }
    }
    
    updateRoundCountDisplay();
  }

  function addNewRound() {
    const rounds = document.querySelectorAll("#rounds-container .round-row").length;
    createStandardRound(rounds + 1);
    reindexRounds();
    updateRoundCountDisplay();
  }

  function addNewPause() {
    createPauseRound();
    reindexRounds();
    updateRoundCountDisplay();
  }

  function applyGlobalTime() {
    const globalInput = document.getElementById("globalTimeInput") as HTMLInputElement | null;
    if (!globalInput) return;
    const minutes = Number(globalInput.value);
    const inputs = document.querySelectorAll("#rounds-container input[id^=time]");
    inputs.forEach((input) => {
      (input as HTMLInputElement).value = minutes.toString();
    });
  }

  function reindexRounds() {
    const rows = document.querySelectorAll("#rounds-container .round-row");
    let roundNumber = 1;

    rows.forEach(row => {
      const isPause = row.hasAttribute("data-pause");
      if (!isPause) {
        const label = row.querySelector(".round-column label");
        if (label) {
          label.textContent = `Round ${roundNumber} – Small Blind`;
          roundNumber++;
        }
      }
    });
    updateRoundCountDisplay();
  }

  function setRound(index: number) {
    const rounds = document.querySelectorAll("#rounds-container .round-row");
    const round = rounds[index];
    if (!round) return;

    const isPause = round.hasAttribute("data-pause");
    const blindsCombined = document.getElementById("blinds-combined");
    const anteDisplay = document.getElementById("ante");

    let seconds = 600;

    if (isPause) {
      if (blindsCombined) blindsCombined.textContent = "Pause";
      if (anteDisplay) anteDisplay.textContent = "";

      const pauseInput = round.querySelector("input[type=number]") as HTMLInputElement;
      seconds = (Number(pauseInput?.value) || 10) * 60;
    } else {
      const smallBlind = round.querySelector("input[id^='small']") as HTMLInputElement;
      const bigBlind = round.querySelector("input[id^='big']") as HTMLInputElement;
      const timeInput = round.querySelector("input[id^='time']") as HTMLInputElement;

      if (smallBlind && bigBlind && blindsCombined) {
        blindsCombined.textContent = `${smallBlind.value} / ${bigBlind.value}`;
      }
      if (anteDisplay && bigBlind) {
        anteDisplay.textContent = `Ante: ${bigBlind.value}`;
      }

      seconds = (Number(timeInput?.value) || 10) * 60;
    }
    
    setRoundSeconds(seconds);

    // --- LOGIKA PRO NEXT BLIND ---
    const nextBlindsDisplay = document.getElementById("next-blinds");
    const nextRound = rounds[index + 1]; // Získání HTML elementu dalšího kola

    if (nextBlindsDisplay) {
      // Skrýt náhled na začátku nového kola (aby se mohl později znovu animovat)
      nextBlindsDisplay.classList.remove("show");

      if (nextRound) {
        const isNextPause = nextRound.hasAttribute("data-pause");
        if (isNextPause) {
          nextBlindsDisplay.textContent = "Next: Pauza";
        } else {
          const nextSmall = nextRound.querySelector("input[id^='small']") as HTMLInputElement;
          const nextBig = nextRound.querySelector("input[id^='big']") as HTMLInputElement;
          if (nextSmall && nextBig) {
            nextBlindsDisplay.textContent = `Next: ${nextSmall.value} / ${nextBig.value}`;
          }
        }
      } else {
        nextBlindsDisplay.textContent = "Next: Konec turnaje";
      }
    }
  }

  function updateRoundCountDisplay() {
    const display = document.getElementById("roundCountDisplay");
    if (!display) return;
    const allRounds = document.querySelectorAll("#rounds-container .round-row");
    let count = 0;
    allRounds.forEach(row => {
      if (!row.hasAttribute("data-pause")) count++;
    });
    display.textContent = `Total rounds created: ${count}`;
  }

  // === MODAL A HELPERS ===
// === MODAL A HELPERS ===
  function openForm() {
    const modalElement = document.getElementById("blindForm");
    // Voláme objekt přes window, aby Astro a TypeScript neprotestovaly
    if (modalElement && (window as any).bootstrap) {
      new (window as any).bootstrap.Modal(modalElement).show();
    }
  }

  function saveBlinds() {
    const roundElements = document.querySelectorAll("#rounds-container .round-row");
    if (roundElements.length === 0) return;

    setRound(0);

    const clockElement = document.getElementById("clock");
    if (clockElement) {
      clockElement.textContent = formatTime(roundSecondsLeft);
    }

    showSaveMessage();

    const modal = document.getElementById("blindForm");
    if (modal && (window as any).bootstrap) {
      (window as any).bootstrap.Modal.getInstance(modal)?.hide();
    }
    saveRoundsToStorage();
  }

  function showSaveMessage() {
    const message = document.getElementById("saveMessage");
    if (!message) return;
    message.classList.remove("d-none");
    message.style.opacity = "1";
    setTimeout(() => {
      message.style.opacity = "0";
      setTimeout(() => message.classList.add("d-none"), 300);
    }, 3000);
  }

  function initLoader() {
    setTimeout(() => {
      document.querySelector('.poker-timer-app')?.classList.add("loaded");
      const loader = document.getElementById('loader');
      if (loader) {
        loader.style.opacity = '0';
        loader.style.visibility = 'hidden';
      }
    }, 500);
  }

  // Připojení funkcí na window objekt, protože se volají přímo z HTML (onclick)
  (window as any).adjustBlind = (inputId: string, change: number) => {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    if (input) {
      const current = Number(input.value) || 0;
      input.value = Math.max(0, current + change).toString();
    }
  };
  (window as any).reindexRounds = reindexRounds;
  (window as any).updateRoundCountDisplay = updateRoundCountDisplay;

  // === INICIALIZACE ===
  initLoader();
  createBlindRounds();

  const openFormBtn = document.getElementById("openForm");
  const saveBlindsBtn = document.getElementById("saveBlinds");
  const applyGlobalTimeBtn = document.getElementById("applyGlobalTimeBtn");
  const playPauseToggle = document.getElementById("playPauseToggle");
  const addRoundBtn = document.getElementById("addRoundBtn");
  const addPauseBtn = document.getElementById("addPauseBtn");
  const blindForm = document.getElementById("blindForm");
  const bottomControls = document.getElementById("bottom-controls");

  openFormBtn?.addEventListener("click", openForm);
  saveBlindsBtn?.addEventListener("click", saveBlinds);
  applyGlobalTimeBtn?.addEventListener("click", applyGlobalTime);
  playPauseToggle?.addEventListener("click", toggleTimer);
  addRoundBtn?.addEventListener("click", addNewRound);
  addPauseBtn?.addEventListener("click", addNewPause);

  if (blindForm && bottomControls) {
    blindForm.addEventListener("show.bs.modal", () => {
      bottomControls.classList.remove("d-none");
    });
    blindForm.addEventListener("hide.bs.modal", () => {
      bottomControls.classList.add("d-none");
    });
  }

  const fullscreenToggle = document.getElementById("fullscreenToggle");

  // Funkce pro přepnutí fullscreenu a změnu ikony
function toggleFullscreen() {
    if (!document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch((err) => console.log(err));
    } else {
      if (document.exitFullscreen) document.exitFullscreen();
    }
  }

  fullscreenToggle?.addEventListener("click", toggleFullscreen);

  // Systémový hlídač – zachytí i stisknutí klávesy ESC
  document.addEventListener('fullscreenchange', () => {
    const nav = document.querySelector('.main-nav') as HTMLElement;
    
    if (document.fullscreenElement) {
      // Jsme ve fullscreenu -> schovat navigaci a změnit ikonku
      if (nav) nav.style.display = 'none';
      fullscreenToggle?.classList.replace("bi-arrows-fullscreen", "bi-fullscreen-exit");
    } else {
      // Jsme zpět v normálním režimu -> ukázat navigaci a změnit ikonku zpět
      if (nav) nav.style.display = 'flex';
      fullscreenToggle?.classList.replace("bi-fullscreen-exit", "bi-arrows-fullscreen");
    }
  });

  // Připojení funkce na tlačítko
  fullscreenToggle?.addEventListener("click", toggleFullscreen);

  document.addEventListener("keydown", (e) => {
    if (e.code === "Space") {
      e.preventDefault();
      toggleTimer();
    }
  });

  const clockElement = document.getElementById("clock");
  if (clockElement) clockElement.textContent = "10:00";
</script>

<style is:global>
  /* === ZÁKLADNÍ ROZVRŽENÍ === */
  html, body {
    background-color: #1a1a1a !important;
    margin: 0;
    padding: 0;
    width: 100%;
    min-height: 100vh;
    overflow-x: hidden;
  }

  .poker-timer-app {
    position: absolute;
    top: 0;
    left: 0;
    width: 100vw;
    min-height: 100vh;
    background-color: #1a1a1a;
    color: #e0e0e0;
    font-family: 'Inter', sans-serif;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* === NAVIGACE === */
  .main-nav {
    position: relative;
    z-index: 9999 !important;
    pointer-events: none !important;
  }
  
  .nav-container {
    pointer-events: auto !important;
  }

  /* === HLAVNÍ OBSAH (HODINY A BLINDY) === */
  #main-content {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    margin-top: 15vh;
    z-index: 10;
  }

  #clock {
    font-size: 18vw;
    text-align: center;
    color: #fafafa;
    line-height: 1; 
  }

  #blinds {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 5vw;
    font-size: 4vw;
    font-weight: 500;
